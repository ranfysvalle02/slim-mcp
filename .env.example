# Smart MCP Gateway -- environment configuration.
# Copy to .env and adjust. Apart from GITHUB_PAT (below), every setting is
# MCPX_-prefixed. The live demo runs on a local Ollama model -- no cloud, no keys.

# --- Upstream GitHub MCP server (REQUIRED) ---------------------------------
# The gateway proxies the real, official GitHub MCP server, so it needs a GitHub
# Personal Access Token. Create one at:
#   https://github.com/settings/personal-access-tokens/new
# A fine-grained, read-only token is plenty for the demo. The gateway will not
# start without this. (Bare name, no MCPX_ prefix, matching GitHub convention.)
GITHUB_PAT=

# Upstream endpoint. `/x/all` exposes every toolset (issues, pulls, repos,
# actions, releases, orgs, search, ...) so the firehose has real tools across
# every area. Override only if you proxy a different GitHub MCP deployment.
# MCPX_GITHUB_REMOTE_URL=https://api.githubcopilot.com/mcp/x/all
# Ask the upstream for a read-only catalog (no write/destructive tools at all).
# MCPX_GITHUB_READONLY=false

# --- Core ------------------------------------------------------------------
ENV=development

# --- Gateway interface (one header, that's it) -----------------------------
# Free-form task description. The gateway embeds it and returns the top-k tools
# by meaning -- their descriptions passed through byte-for-byte. With no query
# header it returns the full catalog (honest proxy).
MCPX_QUERY_HEADER=x-mcp-query

# --- Safety floor ----------------------------------------------------------
# Hide destructive tools (destructiveHint / delete_* / *admin*) in both
# directions -- the only static rule in the gateway. Set false to expose them.
MCPX_BLOCK_DESTRUCTIVE=true
# Per-request tools/list cache.
MCPX_LIST_CACHE_TTL_SECONDS=5.0
MCPX_LIST_CACHE_MAX_ENTRIES=64

# --- Persistence (optional) ------------------------------------------------
# Leave MCPX_MONGO_URI unset to run fully standalone (telemetry becomes a no-op
# and semantic retrieval is disabled -> the gateway serves the full catalog).
# Set it to turn on token_telemetry / invocation_audit / tool_catalog. Uses
# PyMongo's native async API (AsyncMongoClient), not Motor.
# MCPX_MONGO_URI=mongodb://localhost:27019/?directConnection=true
MCPX_MONGO_DATABASE=mcpx

# --- Route by meaning (MongoDB Vector Search) ------------------------------
# The core mechanism. The X-MCP-Query above is embedded and matched against the
# embedded catalog with $vectorSearch, and the top-k come back by meaning.
# Requires Mongo + a seeded catalog (seeds automatically on startup). Falls back
# to the full catalog otherwise.
MCPX_SEMANTIC_RETRIEVAL_ENABLED=true
MCPX_ROUTE_TOP_K=8
# $vectorSearch candidate pool scanned before the top-k is returned.
MCPX_ROUTE_NUM_CANDIDATES=100
# Local embedding model (no keys, on-device). Pull once: ollama pull nomic-embed-text
# Dimensions must match the Vector Search index (nomic-embed-text => 768).
# MCPX_EMBED_MODEL=nomic-embed-text
# MCPX_EMBED_DIMENSIONS=768

# --- Tokenizer -------------------------------------------------------------
MCPX_TOKENIZER_ENCODING=cl100k_base

# --- Local model (fully on-device, no cloud, no keys) ----------------------
# The dashboard's "try it yourself" panel runs on a local Ollama runtime via its
# native API. Install Ollama and pull a model once: ollama pull qwen3:14b  (any
# Ollama model works; smaller ones are faster). Make sure `ollama serve` is running.
# MCPX_OLLAMA_HOST=http://localhost:11434
# MCPX_OLLAMA_MODEL=qwen3:14b
